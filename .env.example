# ============================================================================
# Airflow 3.0 + Spark 4.0 + Kafka + Delta Lake - Environment Configuration
# ============================================================================

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================

# Airflow User ID (Linux: use $(id -u), macOS: 50000)
AIRFLOW_UID=50000

# Project directory path
AIRFLOW_PROJ_DIR=.

# Environment identifier
AIRFLOW_ENV=development

# Server IP (localhost for local dev, your server IP for production)
VPS_IP=localhost

# ============================================================================
# AUTHENTICATION & CREDENTIALS
# ============================================================================

# Airflow Admin User
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=change_me_please

# MinIO/S3 Storage Credentials
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=change_me_please

# ============================================================================
# RESOURCE ALLOCATION
# ============================================================================

# Spark Worker Configuration
SPARK_WORKER_MEMORY=3G
SPARK_WORKER_CORES=2

# ============================================================================
# AIRFLOW API CONFIGURATION
# ============================================================================

# Airflow API Base URL (adjust port if needed)
AIRFLOW__API__BASE_URL=http://localhost:8085

# ============================================================================
# OPTIONAL: PERFORMANCE TUNING
# ============================================================================

# Airflow Scheduler Settings
# AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=30
# AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=10
# AIRFLOW__CORE__DAGBAG_IMPORT_TIMEOUT=30

# Airflow Webserver Settings  
# AIRFLOW__WEBSERVER__WORKERS=2
# AIRFLOW__CELERY__WORKER_CONCURRENCY=4
# AIRFLOW__SCHEDULER__PARSING_PROCESSES=2

# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================

# For local development:
# - Keep VPS_IP=localhost
# - Use default ports
# - Adjust memory based on your machine (8GB minimum recommended)

# For production deployment:
# - Set VPS_IP to your server's public IP
# - Use strong passwords
# - Consider resource limits based on your server specs

# For different environments:
# - AIRFLOW_ENV can be: development, staging, production
# - Adjust SPARK_WORKER_MEMORY based on available RAM
# - Scale SPARK_WORKER_CORES based on CPU cores available