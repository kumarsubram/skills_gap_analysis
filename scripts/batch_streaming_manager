#!/bin/bash
# =============================================================================
# CONFIGURABLE BATCH-AWARE STREAMING MANAGER
# =============================================================================
# Coordinates continuous streaming with daily batch jobs
# Easy to customize timing and DAGs

set -e

# =============================================================================
# 🔧 EASY CONFIGURATION - CUSTOMIZE THESE VALUES
# =============================================================================

# BATCH JOB SCHEDULE (24-hour format)
BATCH_START_HOUR=13              # When batch jobs start (1 PM = 13)
BATCH_END_HOUR=17                # When batch jobs end (5 PM = 17)
PREP_MINUTES=30                  # Prep time before batch (30 minutes)
RECOVERY_MINUTES=30              # Recovery time after batch (30 minutes)

# STREAMING DAG NAMES (add more as needed)
STREAMING_DAGS=(
    "producer_github_events"
    "consumer_github_events"
)

# BATCH DAG NAMES (add more as needed)
BATCH_DAGS=(
    "daily_github_bronze"
    "daily_github_processing_analytics"
    "daily_jobs_bronze"
)

# DISK SPACE THRESHOLDS (percentages)
STREAMING_CLEANUP_AT=60          # Start cleanup during streaming
STREAMING_STOP_AT=75             # Emergency stop during streaming
BATCH_CLEANUP_AT=50              # Start cleanup during batch (more aggressive)
BATCH_STOP_AT=70                 # Emergency stop during batch (more aggressive)

# MONITORING INTERVALS (seconds)
STREAMING_CHECK_INTERVAL=300     # Check every 5 minutes during streaming
BATCH_CHECK_INTERVAL=1800        # Check every 30 minutes during batch
PREP_RECOVERY_INTERVAL=60        # Check every 1 minute during prep/recovery

# CLEANUP RETENTION (hours)
LOG_RETENTION_HOURS=2            # Keep logs for 2 hours
CHECKPOINT_RETENTION_HOURS=1     # Keep checkpoints for 1 hour

# =============================================================================
# SYSTEM SETUP (don't change unless you know what you're doing)
# =============================================================================

LOG_FILE="/tmp/batch_streaming.log"
COLORS=true

# Colors
if [ "$COLORS" = true ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    PURPLE='\033[0;35m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' PURPLE='' NC=''
fi

# Logging functions
log() { echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_FILE"; }
warn() { echo -e "${YELLOW}[$(date '+%Y-%m-%d %H:%M:%S')] ⚠️${NC}  $1" | tee -a "$LOG_FILE"; }
error() { echo -e "${RED}[$(date '+%Y-%m-%d %H:%M:%S')] ❌${NC} $1" | tee -a "$LOG_FILE"; }
info() { echo -e "${BLUE}[$(date '+%Y-%m-%d %H:%M:%S')] ℹ️${NC}  $1" | tee -a "$LOG_FILE"; }
phase() { echo -e "${PURPLE}[$(date '+%Y-%m-%d %H:%M:%S')] 🔄${NC} $1" | tee -a "$LOG_FILE"; }

# =============================================================================
# TIME AND PHASE DETECTION
# =============================================================================

get_current_hour() { date +%H | sed 's/^0*//'; }
get_current_minute() { date +%M | sed 's/^0*//'; }
get_current_time_minutes() {
    local hour=$(get_current_hour)
    local minute=$(get_current_minute)
    echo $((hour * 60 + minute))
}

get_operation_mode() {
    local current_minutes=$(get_current_time_minutes)
    local prep_start_minutes=$(((BATCH_START_HOUR * 60) - PREP_MINUTES))
    local batch_start_minutes=$((BATCH_START_HOUR * 60))
    local batch_end_minutes=$((BATCH_END_HOUR * 60))
    local recovery_end_minutes=$((batch_end_minutes + RECOVERY_MINUTES))
    
    if [ $current_minutes -ge $prep_start_minutes ] && [ $current_minutes -lt $batch_start_minutes ]; then
        echo "prep"
    elif [ $current_minutes -ge $batch_start_minutes ] && [ $current_minutes -lt $batch_end_minutes ]; then
        echo "batch"
    elif [ $current_minutes -ge $batch_end_minutes ] && [ $current_minutes -lt $recovery_end_minutes ]; then
        echo "recovery"
    else
        echo "streaming"
    fi
}

get_minutes_until_next_phase() {
    local current_minutes=$(get_current_time_minutes)
    local mode=$(get_operation_mode)
    
    case $mode in
        prep) echo $((BATCH_START_HOUR * 60 - current_minutes)) ;;
        batch) echo $((BATCH_END_HOUR * 60 - current_minutes)) ;;
        recovery) echo $(((BATCH_END_HOUR * 60 + RECOVERY_MINUTES) - current_minutes)) ;;
        streaming)
            local next_prep=$(((BATCH_START_HOUR * 60) - PREP_MINUTES))
            if [ $current_minutes -lt $next_prep ]; then
                echo $((next_prep - current_minutes))
            else
                echo $(((24 * 60 + next_prep) - current_minutes))
            fi ;;
    esac
}

# =============================================================================
# SYSTEM MONITORING
# =============================================================================

get_disk_usage() { df / | awk 'NR==2 {print int($5)}'; }
get_disk_usage_gb() { df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 ")"}'; }

is_dag_running() {
    local dag_id="$1"
    docker exec airflow-spark-airflow-worker-1 \
        airflow dags list-runs "$dag_id" 2>/dev/null | \
        awk 'NR>2 {print $5}' | \
        grep -q "running\|queued" 2>/dev/null || return 1
}

get_batch_jobs_status() {
    local running_count=0
    local total_count=${#BATCH_DAGS[@]}
    
    for dag in "${BATCH_DAGS[@]}"; do
        if is_dag_running "$dag"; then
            running_count=$((running_count + 1))
        fi
    done
    
    echo "${running_count}/${total_count}"
}

get_streaming_jobs_status() {
    local status_parts=()
    
    for dag in "${STREAMING_DAGS[@]}"; do
        local dag_name=$(echo "$dag" | sed 's/.*_//')
        if is_dag_running "$dag"; then
            status_parts+=("${dag_name}:✅")
        else
            status_parts+=("${dag_name}:❌")
        fi
    done
    
    local IFS=' '
    echo "${status_parts[*]}"
}

# =============================================================================
# DAG MANAGEMENT
# =============================================================================

stop_dag() {
    local dag_id="$1"
    info "Stopping DAG: $dag_id"
    docker exec airflow-spark-airflow-worker-1 bash -c "
        airflow dags pause '$dag_id' 2>/dev/null || true
        airflow tasks clear '$dag_id' --yes --only-running 2>/dev/null || true
    " >/dev/null 2>&1 || warn "Could not fully stop $dag_id"
}

start_dag() {
    local dag_id="$1"
    info "Starting DAG: $dag_id"
    docker exec airflow-spark-airflow-worker-1 bash -c "
        airflow dags unpause '$dag_id' 2>/dev/null || true
        airflow dags trigger '$dag_id' 2>/dev/null || true
    " >/dev/null 2>&1 || warn "Could not start $dag_id"
}

stop_all_streaming_dags() {
    for dag in "${STREAMING_DAGS[@]}"; do
        stop_dag "$dag"
    done
}

start_all_streaming_dags() {
    for dag in "${STREAMING_DAGS[@]}"; do
        start_dag "$dag"
        sleep 30
    done
}

# =============================================================================
# CLEANUP OPERATIONS
# =============================================================================

cleanup_airflow_logs() {
    info "Cleaning Airflow logs (keeping last ${LOG_RETENTION_HOURS}h)"
    for container in airflow-scheduler airflow-worker airflow-triggerer airflow-dag-processor; do
        docker exec "airflow-spark-${container}-1" bash -c "
            find /opt/airflow/logs -type f -name '*.log' -mmin +$((LOG_RETENTION_HOURS * 60)) -delete 2>/dev/null || true
            find /opt/airflow/logs -type d -empty -delete 2>/dev/null || true
        " 2>/dev/null || warn "Could not clean logs in $container"
    done
}

cleanup_spark_resources() {
    info "Cleaning Spark resources"
    for container in spark-master spark-worker-1 spark-worker-2; do
        docker exec "$container" bash -c "
            rm -rf /opt/spark/work/* /opt/spark/logs/* /opt/spark/tmp/* 2>/dev/null || true
            find /tmp -name 'spark-*' -type d -mmin +$((LOG_RETENTION_HOURS * 60)) -exec rm -rf {} + 2>/dev/null || true
        " 2>/dev/null || warn "Could not clean Spark resources in $container"
    done
}

cleanup_streaming_checkpoints() {
    info "Cleaning streaming checkpoints (keeping last ${CHECKPOINT_RETENTION_HOURS}h)"
    docker exec airflow-spark-airflow-worker-1 bash -c "
        find /tmp -name '*checkpoint*' -type d -mmin +$((CHECKPOINT_RETENTION_HOURS * 60)) -exec rm -rf {} + 2>/dev/null || true
        find /tmp -name 'spark-streaming-*' -type d -mmin +$((CHECKPOINT_RETENTION_HOURS * 60)) -exec rm -rf {} + 2>/dev/null || true
    " 2>/dev/null || warn "Could not clean checkpoints"
}

cleanup_kafka_minimal() {
    info "Minimal Kafka cleanup (3h retention handles data)"
    docker exec kafka bash -c "
        find /tmp -name 'kafka-*' -mmin +60 -type f -delete 2>/dev/null || true
    " 2>/dev/null || warn "Could not clean Kafka temp files"
}

cleanup_docker_system() {
    info "Cleaning Docker system resources (preserving data volumes)"
    
    # SAFE cleanup - removed --volumes flag to protect MinIO/Postgres/Kafka data
    docker system prune -f >/dev/null 2>&1 || true
    docker container prune -f >/dev/null 2>&1 || true
    docker image prune -f -a >/dev/null 2>&1 || true
    
    # Only clean truly temporary volumes if they're dangling (unused)
    docker volume ls -qf dangling=true | grep -E "tmp|temp|cache" | xargs -r docker volume rm 2>/dev/null || true
}

perform_full_cleanup() {
    local cleanup_reason="$1"
    log "🧹 FULL CLEANUP: $cleanup_reason"
    
    cleanup_airflow_logs
    cleanup_spark_resources
    cleanup_streaming_checkpoints
    cleanup_kafka_minimal
    cleanup_docker_system
    
    sync
    echo 3 | sudo tee /proc/sys/vm/drop_caches >/dev/null 2>&1 || true
    
    local new_usage=$(get_disk_usage)
    log "✅ Cleanup complete. Disk usage: ${new_usage}%"
}

# =============================================================================
# CONTAINER RESTART MANAGEMENT
# =============================================================================

restart_streaming_containers() {
    log "🔄 Restarting streaming containers"
    stop_all_streaming_dags
    sleep 30
    
    docker restart spark-worker-1 spark-worker-2 >/dev/null 2>&1 || warn "Could not restart Spark workers"
    docker restart airflow-spark-airflow-worker-1 >/dev/null 2>&1 || warn "Could not restart Airflow worker"
    
    sleep 90
    log "✅ Streaming containers restarted"
}

restart_all_containers() {
    log "🔄 Full container restart"
    stop_all_streaming_dags
    sleep 30
    
    docker restart \
        airflow-spark-airflow-worker-1 \
        spark-worker-1 \
        spark-worker-2 \
        spark-master \
        >/dev/null 2>&1 || warn "Some containers failed to restart"
    
    sleep 120
    log "✅ All containers restarted"
}

# =============================================================================
# PHASE-SPECIFIC OPERATIONS
# =============================================================================

handle_prep_phase() {
    phase "PRE-BATCH PREPARATION"
    
    for dag in "${STREAMING_DAGS[@]}"; do
        if is_dag_running "$dag"; then
            stop_dag "$dag"
        fi
    done
    log "🛑 Streaming DAGs stopped for batch preparation"
    
    perform_full_cleanup "pre-batch preparation"
    restart_streaming_containers
    
    local disk_usage=$(get_disk_usage)
    if [ $disk_usage -gt 40 ]; then
        warn "Disk usage still high (${disk_usage}%) after preparation"
    else
        log "✅ System prepared: ${disk_usage}% disk usage"
    fi
}

handle_batch_phase() {
    phase "BATCH PROCESSING MODE"
    
    local disk_usage=$(get_disk_usage)
    local batch_status=$(get_batch_jobs_status)
    
    info "Batch jobs: $batch_status | Disk: ${disk_usage}%"
    
    if [ $disk_usage -gt $BATCH_STOP_AT ]; then
        error "CRITICAL: Disk ${disk_usage}% > ${BATCH_STOP_AT}% during batch"
        stop_all_streaming_dags
        perform_full_cleanup "emergency during batch"
    elif [ $disk_usage -gt $BATCH_CLEANUP_AT ]; then
        warn "High usage during batch: ${disk_usage}% > ${BATCH_CLEANUP_AT}%"
        perform_full_cleanup "high usage during batch"
    fi
}

handle_recovery_phase() {
    phase "POST-BATCH RECOVERY"
    
    perform_full_cleanup "post-batch recovery"
    restart_all_containers
    
    log "🚀 Resuming streaming operations"
    start_all_streaming_dags
    
    log "✅ Recovery complete - back to streaming mode"
}

handle_streaming_phase() {
    phase "STREAMING MODE"
    
    local disk_usage=$(get_disk_usage)
    local streaming_status=$(get_streaming_jobs_status)
    
    info "Streaming: $streaming_status | Disk: ${disk_usage}%"
    
    if [ $disk_usage -gt $STREAMING_STOP_AT ]; then
        error "CRITICAL: Disk ${disk_usage}% > ${STREAMING_STOP_AT}%"
        stop_all_streaming_dags
        perform_full_cleanup "emergency during streaming"
    elif [ $disk_usage -gt $STREAMING_CLEANUP_AT ]; then
        warn "High usage: ${disk_usage}% > ${STREAMING_CLEANUP_AT}%"
        for dag in "${STREAMING_DAGS[@]}"; do
            if [[ "$dag" == *"producer"* ]]; then
                stop_dag "$dag"
            fi
        done
        perform_full_cleanup "high usage during streaming"
    else
        for dag in "${STREAMING_DAGS[@]}"; do
            if ! is_dag_running "$dag"; then
                start_dag "$dag"
                sleep 30
            fi
        done
    fi
}

# =============================================================================
# MAIN MONITORING LOOP
# =============================================================================

main_monitor() {
    log "🚀 BATCH-AWARE STREAMING MANAGER STARTED"
    log "📅 Batch window: ${BATCH_START_HOUR}:00 - ${BATCH_END_HOUR}:00"
    log "⏰ Current time: $(date '+%H:%M')"
    log "💾 Initial disk usage: $(get_disk_usage_gb)"
    log "📡 Streaming DAGs: ${STREAMING_DAGS[*]}"
    log "🏭 Batch DAGs: ${BATCH_DAGS[*]}"
    
    while true; do
        local mode=$(get_operation_mode)
        local minutes_to_next=$(get_minutes_until_next_phase)
        local disk_usage=$(get_disk_usage)
        
        log "📊 Mode: $mode | Disk: ${disk_usage}% | Next phase in: ${minutes_to_next}min"
        
        case $mode in
            prep) handle_prep_phase; sleep $PREP_RECOVERY_INTERVAL ;;
            batch) handle_batch_phase; sleep $BATCH_CHECK_INTERVAL ;;
            recovery) handle_recovery_phase; sleep $PREP_RECOVERY_INTERVAL ;;
            streaming) handle_streaming_phase; sleep $STREAMING_CHECK_INTERVAL ;;
        esac
    done
}

# =============================================================================
# COMMAND LINE INTERFACE
# =============================================================================

show_status() {
    local mode=$(get_operation_mode)
    local disk_usage=$(get_disk_usage)
    local disk_details=$(get_disk_usage_gb)
    local minutes_to_next=$(get_minutes_until_next_phase)
    local streaming_status=$(get_streaming_jobs_status)
    local batch_status=$(get_batch_jobs_status)
    
    echo "📊 BATCH-AWARE STREAMING STATUS"
    echo "================================"
    echo "⏰ Current time: $(date '+%H:%M:%S')"
    echo "🔄 Current mode: $mode"
    echo "⏳ Next phase in: ${minutes_to_next} minutes"
    echo "💾 Disk usage: $disk_details"
    echo "📡 Streaming: $streaming_status"
    echo "🏭 Batch jobs: $batch_status"
    echo "📅 Batch window: ${BATCH_START_HOUR}:00 - ${BATCH_END_HOUR}:00"
}

show_help() {
    cat << EOF
🎯 CONFIGURABLE BATCH-AWARE STREAMING MANAGER

USAGE: $0 <command>

COMMANDS:
    monitor     - Start continuous monitoring (run in screen/tmux)
    status      - Show current system status
    cleanup     - Perform one-time cleanup
    start       - Start all streaming DAGs
    stop        - Stop all streaming DAGs
    restart     - Restart streaming containers
    help        - Show this help

CONFIGURATION:
    Edit the top of this script to customize:
    - Batch timing (BATCH_START_HOUR, BATCH_END_HOUR)
    - DAG lists (STREAMING_DAGS, BATCH_DAGS arrays)
    - Disk thresholds and intervals

EXAMPLES:
    screen -S streaming -dm $0 monitor    # Start monitoring
    $0 status                             # Check status
    $0 cleanup                            # Emergency cleanup

EOF
}

# =============================================================================
# MAIN ENTRY POINT
# =============================================================================

case "${1:-help}" in
    monitor) main_monitor ;;
    status) show_status ;;
    cleanup) perform_full_cleanup "manual cleanup" ;;
    start) start_all_streaming_dags ;;
    stop) stop_all_streaming_dags ;;
    restart) restart_streaming_containers ;;
    help|--help|-h) show_help ;;
    *) echo "❌ Unknown command: $1"; show_help; exit 1 ;;
esac
